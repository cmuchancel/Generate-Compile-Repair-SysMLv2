        <mxCell id="wC" value="&lt;b&gt;3C) Worker C (Looped)&lt;/b&gt;&lt;br&gt;Build SysML for Concept C&lt;br&gt;Optimize mid-level requirements&lt;br&gt;Run parts picker" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacing=8;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="1080" y="480" width="300" height="110" as="geometry"/>
        </mxCell>

        <mxCell id="checker" value="&lt;b&gt;4) Constraint Checker&lt;/b&gt;&lt;br&gt;Verify selected parts satisfy prompt constraints for each design" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacing=8;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="1080" y="650" width="300" height="100" as="geometry"/>
        </mxCell>

        <mxCell id="decision" value="&lt;b&gt;All pass?&lt;/b&gt;" style="rhombus;whiteSpace=wrap;html=1;align=center;verticalAlign=middle;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1420" y="665" width="130" height="80" as="geometry"/>
        </mxCell>

        <mxCell id="outputs" value="&lt;b&gt;Final Outputs (Slide Deliverable)&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacing=8;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=14;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1580" y="120" width="320" height="760" as="geometry"/>
        </mxCell>

        <mxCell id="outA" value="&lt;b&gt;Design A: Discrete CC/CV Buck&lt;/b&gt;&lt;br&gt;Picked parts:&lt;br&gt;- LM2596 buck regulator&lt;br&gt;- 33uH inductor&lt;br&gt;- SS54 Schottky diode&lt;br&gt;- 0.05 ohm current shunt&lt;br&gt;- NTC thermistor + 2.5A fuse" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacing=6;fillColor=#ffffff;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="1600" y="175" width="280" height="155" as="geometry"/>
        </mxCell>

        <mxCell id="outB" value="&lt;b&gt;Design B: Smart Charger Controller&lt;/b&gt;&lt;br&gt;Picked parts:&lt;br&gt;- BQ24650 charger controller&lt;br&gt;- Dual N-MOSFET power stage&lt;br&gt;- 10mOhm sense resistor&lt;br&gt;- NTC thermistor cutoff&lt;br&gt;- TVS diode + resettable fuse" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacing=6;fillColor=#ffffff;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="1600" y="345" width="280" height="155" as="geometry"/>
        </mxCell>

        <mxCell id="outC" value="&lt;b&gt;Design C: Module + BMS Stack&lt;/b&gt;&lt;br&gt;Picked parts:&lt;br&gt;- CC/CV charger module&lt;br&gt;- 4S BMS balancing board&lt;br&gt;- Reverse-polarity MOSFET&lt;br&gt;- Temperature sensor&lt;br&gt;- Relay cutoff stage" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacing=6;fillColor=#ffffff;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="1600" y="515" width="280" height="145" as="geometry"/>
        </mxCell>

        <mxCell id="finalselect" value="&lt;b&gt;Selected baseline for demo:&lt;/b&gt; Design B&lt;br&gt;Reason: strongest safety/control margin with clear automated stop logic.&lt;br&gt;&lt;br&gt;&lt;b&gt;Delivered assets:&lt;/b&gt;&lt;br&gt;- 3 parts-assigned SysML design candidates&lt;br&gt;- constraint compliance matrix&lt;br&gt;- selected baseline recommendation" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacing=6;fillColor=#f5f5f5;strokeColor=#666666;fontSize=11;" vertex="1" parent="1">
