  <diagram id="concept-parallel-pipeline" name="Concept Parallel Pipeline">
    <mxGraphModel dx="2300" dy="1300" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="3200" pageHeight="1300" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <mxCell id="title" value="SysML Design Pipeline: 1 Prompt -> 3 Parallel Designs" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=24;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="30" y="20" width="920" height="40" as="geometry"/>
        </mxCell>

        <mxCell id="note_loop" value="&lt;b&gt;Implicit Rule:&lt;/b&gt; Every SysML generation step runs compiler-in-the-loop (generate -> validate -> repair -> retry)." style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=middle;spacing=8;fillColor=#fff2cc;strokeColor=#d6b656;dashed=1;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="320" y="70" width="900" height="50" as="geometry"/>
        </mxCell>

        <mxCell id="s1" value="&lt;b&gt;1) NL Requirements Prompt&lt;/b&gt;&lt;br&gt;Output: One natural-language requirements set" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacing=8;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="30" y="150" width="260" height="100" as="geometry"/>
        </mxCell>

        <mxCell id="s2" value="&lt;b&gt;2) SysML Coding Bot (Looped)&lt;/b&gt;&lt;br&gt;Output: Structured SysML requirements model" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacing=8;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="330" y="150" width="290" height="100" as="geometry"/>
        </mxCell>

        <mxCell id="s3" value="&lt;b&gt;3) Concept Brainstorm Agent&lt;/b&gt;&lt;br&gt;Output: 3 candidate concepts" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacing=8;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="660" y="150" width="280" height="100" as="geometry"/>
        </mxCell>

        <mxCell id="label_parallel" value="&lt;b&gt;Parallel Build Tracks&lt;/b&gt;" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=14;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="980" y="90" width="230" height="30" as="geometry"/>
        </mxCell>

        <mxCell id="wA" value="&lt;b&gt;4A) Worker A (Looped)&lt;/b&gt;&lt;br&gt;Build SysML model from Concept A&lt;br&gt;Output: Draft Design A" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacing=8;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="980" y="50" width="290" height="115" as="geometry"/>
        </mxCell>

        <mxCell id="wB" value="&lt;b&gt;4B) Worker B (Looped)&lt;/b&gt;&lt;br&gt;Build SysML model from Concept B&lt;br&gt;Output: Draft Design B" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacing=8;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="980" y="190" width="290" height="115" as="geometry"/>
        </mxCell>

        <mxCell id="wC" value="&lt;b&gt;4C) Worker C (Looped)&lt;/b&gt;&lt;br&gt;Build SysML model from Concept C&lt;br&gt;Output: Draft Design C" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacing=8;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="980" y="330" width="290" height="115" as="geometry"/>
        </mxCell>

        <mxCell id="oA" value="&lt;b&gt;5A) Mid-Level Optimization (Looped)&lt;/b&gt;&lt;br&gt;Optimize Design A against mid-level requirements&lt;br&gt;Output: Optimized Design A" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacing=8;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="1320" y="50" width="330" height="115" as="geometry"/>
        </mxCell>

        <mxCell id="oB" value="&lt;b&gt;5B) Mid-Level Optimization (Looped)&lt;/b&gt;&lt;br&gt;Optimize Design B against mid-level requirements&lt;br&gt;Output: Optimized Design B" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacing=8;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="1320" y="190" width="330" height="115" as="geometry"/>
        </mxCell>

        <mxCell id="oC" value="&lt;b&gt;5C) Mid-Level Optimization (Looped)&lt;/b&gt;&lt;br&gt;Optimize Design C against mid-level requirements&lt;br&gt;Output: Optimized Design C" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacing=8;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="1320" y="330" width="330" height="115" as="geometry"/>
        </mxCell>

        <mxCell id="pA" value="&lt;b&gt;6A) Parts Picker&lt;/b&gt;&lt;br&gt;Select parts to fulfill Design A&lt;br&gt;Output: Parts-assigned Design A" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacing=8;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="1700" y="50" width="300" height="115" as="geometry"/>
        </mxCell>

        <mxCell id="pB" value="&lt;b&gt;6B) Parts Picker&lt;/b&gt;&lt;br&gt;Select parts to fulfill Design B&lt;br&gt;Output: Parts-assigned Design B" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacing=8;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="1700" y="190" width="300" height="115" as="geometry"/>
        </mxCell>

        <mxCell id="pC" value="&lt;b&gt;6C) Parts Picker&lt;/b&gt;&lt;br&gt;Select parts to fulfill Design C&lt;br&gt;Output: Parts-assigned Design C" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacing=8;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="1700" y="330" width="300" height="115" as="geometry"/>
        </mxCell>

        <mxCell id="s6" value="&lt;b&gt;7) Constraint Checker&lt;/b&gt;&lt;br&gt;Validate that selected parts satisfy requirements for each design&lt;br&gt;Output: Pass/fail status per design" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacing=8;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="2040" y="160" width="330" height="130" as="geometry"/>
        </mxCell>

        <mxCell id="d1" value="&lt;b&gt;8) All designs pass&#xa;constraints?&lt;/b&gt;" style="rhombus;whiteSpace=wrap;html=1;align=center;verticalAlign=middle;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=12;fontStyle=1;" vertex="1" parent="1">
