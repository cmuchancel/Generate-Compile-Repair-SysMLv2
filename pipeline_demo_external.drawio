<mxfile host="app.diagrams.net" modified="2026-02-24T00:00:00.000Z" agent="Codex" version="24.7.17">
  <diagram id="pipeline-demo-external" name="Pipeline Demo (External)">
    <mxGraphModel dx="2360" dy="1260" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="2800" pageHeight="1200" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <mxCell id="title" value="Pipeline Demo: Self-Contained Compiler-in-the-Loop" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=26;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="980" height="40" as="geometry"/>
        </mxCell>

        <mxCell id="s1" value="&lt;b&gt;1) Requirements Intake&lt;/b&gt;&lt;br&gt;Deliverable:&lt;br&gt;A clear, scoped problem statement with constraints and acceptance criteria." style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacing=8;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="40" y="110" width="290" height="130" as="geometry"/>
        </mxCell>

        <mxCell id="s2" value="&lt;b&gt;2) Draft Model Generation (M_t)&lt;/b&gt;&lt;br&gt;Deliverable:&lt;br&gt;An initial executable system-model candidate." style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacing=8;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="370" y="110" width="300" height="130" as="geometry"/>
        </mxCell>

        <mxCell id="s3" value="&lt;b&gt;3) Automated Compile &amp; Validation&lt;/b&gt;&lt;br&gt;Deliverable:&lt;br&gt;A structured diagnostics report (errors, warnings, and locations)." style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacing=8;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="710" y="110" width="330" height="130" as="geometry"/>
        </mxCell>

        <mxCell id="d1" value="&lt;b&gt;4) Validation&#xa;passes?&lt;/b&gt;" style="rhombus;whiteSpace=wrap;html=1;align=center;verticalAlign=middle;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1080" y="125" width="190" height="100" as="geometry"/>
        </mxCell>

        <mxCell id="s5" value="&lt;b&gt;5) Guided Revision Loop (M_t+1)&lt;/b&gt;&lt;br&gt;Deliverable:&lt;br&gt;A revised candidate that explicitly addresses each reported issue." style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacing=8;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="1030" y="310" width="340" height="120" as="geometry"/>
        </mxCell>

        <mxCell id="s6" value="&lt;b&gt;6) Validation Complete&lt;/b&gt;&lt;br&gt;Deliverable:&lt;br&gt;A compiler-clean final model plus an auditable refinement history." style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacing=8;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="1310" y="110" width="300" height="130" as="geometry"/>
        </mxCell>

        <mxCell id="s7" value="&lt;b&gt;7) Quality Evaluation&lt;/b&gt;&lt;br&gt;Deliverable:&lt;br&gt;Objective semantic quality scores and identified coverage gaps." style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacing=8;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="1650" y="110" width="300" height="130" as="geometry"/>
        </mxCell>

        <mxCell id="s8" value="&lt;b&gt;8) Cross-Case Analysis&lt;/b&gt;&lt;br&gt;Deliverable:&lt;br&gt;Aggregated performance metrics, error taxonomy, and recovery trends." style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacing=8;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="1990" y="105" width="330" height="140" as="geometry"/>
        </mxCell>

        <mxCell id="s9" value="&lt;b&gt;9) External Reporting Package&lt;/b&gt;&lt;br&gt;Deliverable:&lt;br&gt;Executive summary, decision-ready visuals, and reproducible findings." style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacing=8;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;" vertex="1" parent="1">
